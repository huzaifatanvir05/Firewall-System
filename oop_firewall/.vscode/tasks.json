{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "CMake: Configure Firewall",
            "type": "shell",
            "command": "cmake",
            "args": [
                "-G", "MinGW Makefiles",
                "-S", "${workspaceFolder}",
                "-B", "${workspaceFolder}/build",
                "-DNPCAP_SDK_DIR=C:/Users/DELL/Downloads/npcap-sdk-1.16",
                "-DCMAKE_BUILD_TYPE=Release"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": ["$gcc"],
            "group": {
                "kind": "build",
                "isDefault": false
            }
        },
        {
            "label": "CMake: Build Firewall",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build", "${workspaceFolder}/build",
                "--parallel"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": ["$gcc"],
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "dependsOn": ["CMake: Configure Firewall"]
        },
        {
            "label": "Build and Run Firewall",
            "type": "shell",
            "command": "cmd.exe",
            "args": [
                "/c",
                "cmake --build \"${workspaceFolder}/build\" --parallel && \"${workspaceFolder}\\bin\\Release\\firewall_system.exe\""
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [],
            "dependsOn": ["CMake: Configure Firewall"],
            "dependsOrder": "sequence",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": true,
                "panel": "shared"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            }
        },
        {
            "label": "Run Firewall",
            "type": "shell",
            "command": "${workspaceFolder}\\bin\\Release\\firewall_system.exe",
            "group": "test",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": true,
                "panel": "shared"
            },
            "problemMatcher": []
        }
    ]
}